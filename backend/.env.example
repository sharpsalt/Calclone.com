DATABASE_URL=postgresql://postgres:postgres@localhost:5433/calclone
PORT=4000
DEFAULT_USERNAME=srijan

LOG_LEVEL=info
SERVICE_NAME=calclone-backend

CORS_ORIGIN=http://localhost:5173,http://localhost:5174,http://localhost:5175
ALLOW_LOCALHOST_ORIGINS=true
REDIS_URL=redis://localhost:6379

# Rate limits
PUBLIC_READ_RATE_LIMIT_MAX=60
PUBLIC_READ_RATE_LIMIT_WINDOW_SECONDS=60
BOOKING_CREATE_RATE_LIMIT_MAX=10
BOOKING_CREATE_RATE_LIMIT_WINDOW_SECONDS=1

# Public read cache tuning
PUBLIC_EVENT_CACHE_TTL_SECONDS=60
PUBLIC_EVENT_CACHE_STALE_SECONDS=300
PUBLIC_PROFILE_CACHE_TTL_SECONDS=60
PUBLIC_PROFILE_CACHE_STALE_SECONDS=300
PUBLIC_SLOTS_CACHE_TTL_SECONDS=30
PUBLIC_SLOTS_CACHE_STALE_SECONDS=120

# Bookings pagination
BOOKINGS_DEFAULT_PAGE_SIZE=10

# Email / worker provider settings
# Pick a provider: "smtp" (via Gmail or generic SMTP), "sendgrid", "resend"
EMAIL_PROVIDER=resend
EMAIL_FROM=no-reply@example.com
RESEND_API_KEY=

# SMTP / Gmail (preferred for development demo)
# Option A: Gmail app password (recommended for personal/dev testing)
GMAIL_USER=you@gmail.com
GMAIL_APP_PASSWORD=your_16_char_app_password

# Option B: Generic SMTP
SMTP_HOST=smtp.example.com
SMTP_PORT=465
SMTP_USER=smtp-user
SMTP_PASS=smtp-pass

# For local MailHog (development):
# 1) run MailHog (Docker): docker run -d -p 1025:1025 -p 8025:8025 mailhog/mailhog
# 2) set the following in your .env: SMTP_HOST=localhost, SMTP_PORT=1025
# MailHog accepts unauthenticated SMTP on port 1025 and shows UI at http://localhost:8025

# Optional notification / from addresses
FROM_EMAIL=no-reply@calclone.example
HOST_NOTIFICATION_EMAIL=host@example.com

# URLs
PUBLIC_BASE_URL=http://localhost:5173
API_BASE_URL=http://localhost:4000

# Queue / worker
# Redis URL already defined above; this is the BullMQ queue name
BULLMQ_QUEUE_NAME=calclone-jobs

# Notes:
# - Do NOT commit real secrets. Copy this file to `.env` and fill real values locally.
# - For Gmail: enable 2-step verification and create an App Password to use in `GMAIL_APP_PASSWORD`.
